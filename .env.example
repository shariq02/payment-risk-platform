# ====================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your actual values
# Never commit .env to GitHub
# ====================================================================

# ====================================================================
# POSTGRESQL CONFIGURATION
# ====================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=payment_risk_platform
POSTGRES_USER=your_postgres_username
POSTGRES_PASSWORD=your_postgres_password

# ====================================================================
# AIRFLOW CONFIGURATION
# ====================================================================
AIRFLOW_HOME=/home/your_wsl_username/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False

# ====================================================================
# DBT CONFIGURATION
# ====================================================================
DBT_PROFILES_DIR=/path/to/dbt/profiles

# ====================================================================
# FASTAPI CONFIGURATION
# ====================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ====================================================================
# RISK THRESHOLDS
# ====================================================================
HIGH_VALUE_THRESHOLD=500
HIGH_RISK_SCORE_THRESHOLD=0.7
SELLER_LATE_DELIVERY_THRESHOLD=0.15
SELLER_MIN_ORDERS_THRESHOLD=5
